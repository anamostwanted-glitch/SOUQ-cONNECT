rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, name, role, companyName, phone, location, website, logoUrl, categories, keywords, language, createdAt, following
    //
    // Collection: categories
    // Fields: nameAr, nameEn, parentId, order, keywords, suggestedKeywords, categoryType, createdAt
    //
    // Collection: requests
    // Fields: customerId, productName, categoryId, status, createdAt
    //
    // Collection: offers
    // Fields: requestId, supplierId, price, message, status, createdAt
    //
    // Collection: chats
    // Fields: requestId, customerId, supplierId, lastMessage, updatedAt, isCategoryChat, categoryId
    //
    // Collection: messages (subcollection of chats)
    // Fields: chatId, senderId, text, audioUrl, imageUrl, type, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && (
        request.auth.token.get('role', '') == role || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == role)
      );
    }

    function isMasterAdmin() {
      let email = request.auth.token.get('email', '').lower();
      return isAuthenticated() && (
        email == "anamostwanted@gmail.com" ||
        request.auth.uid == "1mcuGQd7vVhFsuNNawk5EYRw8pB3"
      );
    }

    function isAdmin() {
      let role = request.auth.token.get('role', '');
      return isAuthenticated() && (
        isMasterAdmin() ||
        role in ['admin', 'manager', 'supervisor'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') in ['admin', 'manager', 'supervisor'])
      );
    }

    function isSupplier() {
      return isAuthenticated() && (
        request.auth.token.get('role', '') == 'supplier' || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'supplier')
      );
    }

    // Analytics Events
    match /analytics_events/{eventId} {
      allow create: if isAuthenticated() || request.auth == null; // Allow anonymous session tracking
      allow read, update, delete: if isAdmin();
    }

    function isValidUser(data) {
      let allowedFields = ['uid', 'email', 'role', 'name', 'companyName', 'phone', 'location', 'coordinates', 'website', 'logoUrl', 'coverUrl', 'photoURL', 'photoUrl', 'providerId', 'categories', 'keywords', 'language', 'createdAt', 'updatedAt', 'lastActive', 'bio', 'businessDescription', 'supplierType', 'rating', 'reviewCount', 'verificationDocUrl', 'isVerified', 'verificationDetails', 'verificationExpiryDate', 'trustScore', 'followersCount', 'followingCount', 'followers', 'following', 'logoGenerationUsage', 'isOnline', 'isDeleted', 'lastLoginAt', 'averageResponseTime', 'notificationPreferences', 'conciergeConsent', 'branding', 'referralPoints', 'loyaltyPoints', 'commercialRegistration', 'subscriptionPlan', 'subscriptionExpiry', 'referralCode', 'referredBy', 'onboardingCompleted', 'favoriteProducts', 'aiInsights', 'aiBio', 'socialLinks', 'status', 'deletedAt', 'deletedBy'];
      return data.get('uid', '') is string &&
             data.get('email', '') is string &&
             data.get('role', '') in ['admin', 'supplier', 'customer', 'manager', 'supervisor'] &&
             data.keys().hasOnly(allowedFields) &&
             (!('name' in data) || (data.name is string && data.name.size() < 128)) &&
             (!('companyName' in data) || (data.companyName is string && data.companyName.size() < 256)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() < 32)) &&
             (!('location' in data) || (data.location is string && data.location.size() < 512)) &&
             (!('coordinates' in data) || data.coordinates is map) &&
             (!('website' in data) || (data.website is string && data.website.size() < 512)) &&
             (!('logoUrl' in data) || (data.logoUrl is string && data.logoUrl.size() < 1024)) &&
             (!('coverUrl' in data) || (data.coverUrl is string && data.coverUrl.size() < 1024)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 1024)) &&
             (!('photoUrl' in data) || (data.photoUrl is string && data.photoUrl.size() < 1024)) &&
             (!('providerId' in data) || (data.providerId is string && data.providerId.size() < 128)) &&
             (!('categories' in data) || (data.categories is list && data.categories.size() < 50)) &&
             (!('keywords' in data) || (data.keywords is list && data.keywords.size() < 100)) &&
             (!('language' in data) || data.language in ['ar', 'en']) &&
             (!('createdAt' in data) || (data.createdAt is string || data.createdAt is timestamp)) &&
             (!('updatedAt' in data) || (data.updatedAt is string || data.updatedAt is timestamp)) &&
             (!('lastActive' in data) || (data.lastActive is string && data.lastActive.size() < 64)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() < 2000)) &&
             (!('businessDescription' in data) || (data.businessDescription is string && data.businessDescription.size() < 5000)) &&
             (!('supplierType' in data) || data.supplierType in ['merchant', 'service_provider', 'both']) &&
             (!('rating' in data) || (data.rating is number && data.rating >= 0 && data.rating <= 5)) &&
             (!('reviewCount' in data) || (data.reviewCount is number && data.reviewCount >= 0)) &&
             (!('verificationDocUrl' in data) || (data.verificationDocUrl is string && data.verificationDocUrl.size() < 1024)) &&
             (!('isVerified' in data) || data.isVerified is bool) &&
             (!('verificationDetails' in data) || (data.verificationDetails is string && data.verificationDetails.size() < 5000)) &&
             (!('verificationExpiryDate' in data) || (data.verificationExpiryDate == null || data.verificationExpiryDate is string)) &&
             (!('trustScore' in data) || data.trustScore is number) &&
             (!('followersCount' in data) || data.followersCount is number) &&
             (!('followingCount' in data) || data.followingCount is number) &&
             (!('followers' in data) || (data.followers is list && data.followers.size() < 10000)) &&
             (!('following' in data) || (data.following is list && data.following.size() < 1000)) &&
             (!('logoGenerationUsage' in data) || data.logoGenerationUsage is map) &&
             (!('isOnline' in data) || data.isOnline is bool) &&
             (!('isDeleted' in data) || data.isDeleted is bool) &&
             (!('lastLoginAt' in data) || (data.lastLoginAt is string && data.lastLoginAt.size() < 64)) &&
             (!('averageResponseTime' in data) || data.averageResponseTime is number) &&
             (!('notificationPreferences' in data) || data.notificationPreferences is map) &&
             (!('conciergeConsent' in data) || data.conciergeConsent is bool) &&
             (!('branding' in data) || data.branding is map) &&
             (!('referralPoints' in data) || (data.referralPoints is number && data.referralPoints >= 0)) &&
             (!('loyaltyPoints' in data) || (data.loyaltyPoints is number && data.loyaltyPoints >= 0)) &&
             (!('commercialRegistration' in data) || (data.commercialRegistration is string && data.commercialRegistration.size() < 128)) &&
             (!('subscriptionPlan' in data) || data.subscriptionPlan in ['basic', 'pro', 'enterprise']) &&
             (!('subscriptionExpiry' in data) || (data.subscriptionExpiry is string && data.subscriptionExpiry.size() < 64)) &&
             (!('referralCode' in data) || (data.referralCode is string && data.referralCode.size() < 32)) &&
             (!('referredBy' in data) || (data.referredBy is string && data.referredBy.size() < 128)) &&
             (!('onboardingCompleted' in data) || data.onboardingCompleted is bool) &&
             (!('favoriteProducts' in data) || (data.favoriteProducts is list && data.favoriteProducts.size() < 1000)) &&
             (!('aiInsights' in data) || data.aiInsights is map) &&
             (!('aiBio' in data) || data.aiBio is map) &&
             (!('socialLinks' in data) || data.socialLinks is map) &&
             (!('status' in data) || data.status in ['active', 'deleted', 'suspended', 'pending', 'pending_verification']) &&
             (!('deletedAt' in data) || (data.deletedAt is string && data.deletedAt.size() < 64)) &&
             (!('deletedBy' in data) || (data.deletedBy is string && data.deletedBy.size() < 128));
    }

    function roleUnchanged() {
      return !('role' in request.resource.data) || request.resource.data.role == resource.data.get('role', '');
    }

    match /invites/{email} {
      allow read: if isAuthenticated() && request.auth.token.get('email', '') == email;
      allow write: if isAdmin();
    }

    function isValidReferralUpdate() {
      let oldPoints = ('referralPoints' in resource.data) ? resource.data.referralPoints : 0;
      let newPoints = ('referralPoints' in request.resource.data) ? request.resource.data.referralPoints : 0;
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['referralPoints']) &&
             (newPoints == oldPoints + 10 || newPoints == 0);
    }

    match /users/{userId} {
      // PII Protection: Only owner or admin can read full profile.
      // Exception: Allow reading profiles for marketplace visibility and chat context.
      allow read: if isAuthenticated() || isMasterAdmin() || isAdmin();
      
      allow create: if isAuthenticated() && (
                      request.auth.uid == userId || 
                      isAdmin()
                    ) && isValidUser(request.resource.data);
      
      allow update: if isAuthenticated() && (
                    (isAdmin() && isValidUser(request.resource.data)) || 
                    (request.auth.uid == userId && isValidUser(request.resource.data) && roleUnchanged() && 
                     !request.resource.data.diff(resource.data).affectedKeys().hasAny(['trustScore', 'rating', 'reviewCount']) &&
                     (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['referralPoints']) || request.resource.data.referralPoints == 0)) ||
                    (
                      // Allow following/unfollowing or rating by other users
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers', 'followersCount', 'following', 'followingCount', 'rating', 'reviewCount']) &&
                      isValidUser(request.resource.data)
                    )
                  );
      // Allow admins to hard delete users
      allow delete: if isAdmin();

      match /passkeys/{keyId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidPasskey(incoming());
        allow update: if isOwner(userId) && 
                         isValidPasskey(incoming()) && 
                         incoming().diff(existing()).affectedKeys().hasOnly(['lastUsedAt', 'name']);
        allow delete: if isOwner(userId);
      }
    }

    function isValidPasskey(data) {
       return data.userId == request.auth.uid &&
              data.get('credentialId', '') is string &&
              data.get('publicKey', '') is string &&
              data.get('name', '') is string && data.name.size() < 128;
    }

    match /users_public/{userId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.get('status', '') != 'deleted');
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    function isValidCategory(data) {
      let allowedFields = ['id', 'nameAr', 'nameEn', 'parentId', 'order', 'keywords', 'suggestedKeywords', 'autoKeywords', 'defaultSupplierId', 'categoryType', 'createdAt', 'status', 'deletedAt'];
      return data.keys().hasAll(['nameAr', 'nameEn']) &&
             data.nameAr is string && data.nameAr.size() < 128 &&
             data.nameEn is string && data.nameEn.size() < 128 &&
             (!('parentId' in data) || (data.parentId == null || data.parentId is string)) &&
             (!('order' in data) || data.order is number) &&
             (!('keywords' in data) || (data.keywords is list && data.keywords.size() < 100)) &&
             (!('suggestedKeywords' in data) || (data.suggestedKeywords is list && data.suggestedKeywords.size() < 100)) &&
             (!('autoKeywords' in data) || (data.autoKeywords is list && data.autoKeywords.size() < 100)) &&
             (!('defaultSupplierId' in data) || data.defaultSupplierId is string) &&
             (!('categoryType' in data) || data.categoryType in ['product', 'service', 'main', 'sub']) &&
             (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() < 64)) &&
             (!('status' in data) || data.status in ['active', 'deleted']) &&
             (!('deletedAt' in data) || (data.deletedAt is string && data.deletedAt.size() < 64));
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if (isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'supplier')) && 
                      isValidCategory(request.resource.data) &&
                      (isAdmin() || request.resource.data.status == 'pending');
      allow update: if (isAdmin() && isValidCategory(request.resource.data)) ||
                       (isAuthenticated() && 
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['keywords', 'suggestedKeywords', 'autoKeywords']) &&
                        isValidCategory(request.resource.data));
      allow delete: if false; // Soft delete only
    }

    function isValidProductRequest(data) {
      let allowedFields = ['customerId', 'customerName', 'supplierId', 'supplierName', 'productName', 'description', 'status', 'createdAt', 'type', 'imageUrl', 'attributes', 'aiReasoning', 'deletedAt'];
      return data.keys().hasAll(['customerId', 'supplierId', 'productName', 'status', 'createdAt', 'type']) &&
             data.customerId is string &&
             data.supplierId is string &&
             data.productName is string && data.productName.size() < 256 &&
             data.status in ['pending', 'accepted', 'rejected', 'completed', 'deleted'] &&
             data.type == 'visual_search_rfq' &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('customerName' in data) || (data.customerName is string && data.customerName.size() < 256)) &&
             (!('supplierName' in data) || (data.supplierName is string && data.supplierName.size() < 256)) &&
             (!('description' in data) || (data.description is string && data.description.size() < 5000)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 5000000)) &&
             (!('attributes' in data) || data.attributes is map) &&
             (!('deletedAt' in data) || (data.deletedAt is string && data.deletedAt.size() < 64));
    }

    match /product_requests/{requestId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (resource != null && (resource.data.customerId == request.auth.uid || resource.data.supplierId == request.auth.uid))
      );
      allow create: if isAuthenticated() && request.resource.data.customerId == request.auth.uid && isValidProductRequest(request.resource.data);
      allow update: if isAuthenticated() && (
        (resource.data.customerId == request.auth.uid && isValidProductRequest(request.resource.data)) || 
        (resource.data.supplierId == request.auth.uid && isValidProductRequest(request.resource.data)) ||
        isAdmin()
      );
      allow delete: if false; // Soft delete only
    }

    function isValidRequest(data) {
      let allowedFields = ['customerId', 'customerName', 'productName', 'status', 'createdAt', 'description', 'imageUrl', 'categoryId', 'categoryNameAr', 'categoryNameEn', 'location', 'offerCount', 'quantity', 'budget', 'approvedSuppliers', 'suggestedSupplierIds', 'aiReasoning', 'requestType', 'urgency', 'deletedAt'];
      return data.keys().hasAll(['customerId', 'productName', 'status', 'createdAt']) &&
             data.customerId is string &&
             data.productName is string && data.productName.size() < 256 &&
             data.status in ['open', 'closed', 'cancelled', 'deleted'] &&
             (!('requestType' in data) || data.requestType in ['product', 'service']) &&
             (!('urgency' in data) || data.urgency in ['normal', 'soon', 'urgent', 'high', 'critical']) &&
             (!('customerName' in data) || (data.customerName is string && data.customerName.size() < 256)) &&
             (!('categoryNameAr' in data) || (data.categoryNameAr is string && data.categoryNameAr.size() < 256)) &&
             (!('categoryNameEn' in data) || (data.categoryNameEn is string && data.categoryNameEn.size() < 256)) &&
             (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() < 64)) &&
             (!('description' in data) || (data.description is string && data.description.size() < 5000)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 1024)) &&
             (!('categoryId' in data) || (data.categoryId is string && data.categoryId.size() < 128)) &&
             (!('location' in data) || (data.location is string && data.location.size() < 512)) &&
             (!('offerCount' in data) || data.offerCount is number) &&
            (!('quantity' in data) || (data.quantity is string || data.quantity is number)) &&
             (!('budget' in data) || (data.budget == null || data.budget is number || data.budget is string)) &&
             (!('approvedSuppliers' in data) || (data.approvedSuppliers is list && data.approvedSuppliers.size() < 50)) &&
             (!('suggestedSupplierIds' in data) || (data.suggestedSupplierIds is list && data.suggestedSupplierIds.size() < 50)) &&
             (!('deletedAt' in data) || (data.deletedAt is string && data.deletedAt.size() < 64));
    }

    match /requests/{requestId} {
      allow read: if (resource != null && resource.data.status == 'open') || (
        isAuthenticated() && (
          isAdmin() ||
          (resource != null && (
            resource.data.customerId == request.auth.uid || 
            (resource.data.get('approvedSuppliers', []) is list && request.auth.uid in resource.data.approvedSuppliers) ||
            (resource.data.get('suggestedSupplierIds', []) is list && request.auth.uid in resource.data.suggestedSupplierIds)
          ))
        )
      );
      allow create: if isAuthenticated() && (incoming().customerId == request.auth.uid || isAdmin()) && isValidRequest(incoming());
      allow update: if isAuthenticated() && (
        (isAdmin() && isValidRequest(incoming())) ||
        (resource.data.customerId == request.auth.uid && 
         isValidRequest(incoming()) && 
         existing().status == 'open' && // Terminal State Locking
         incoming().customerId == existing().customerId // Immutability
        )
      );
      allow delete: if false; // Soft delete only
    }

    function isValidOffer(data) {
      let allowedFields = ['requestId', 'supplierId', 'customerId', 'price', 'status', 'createdAt', 'message', 'notes', 'deliveryTime', 'supplierName', 'supplierCompanyName', 'minPrice', 'autoNegotiate', 'deletedAt'];
      return data.keys().hasAll(['requestId', 'supplierId', 'price', 'status', 'createdAt']) &&
             data.requestId is string && data.requestId.size() < 128 &&
             data.supplierId is string && data.supplierId.size() < 128 &&
             (!('customerId' in data) || (data.customerId is string && data.customerId.size() < 128)) &&
             data.price is number &&
             data.status in ['pending', 'accepted', 'rejected', 'negotiating', 'deleted'] &&
             (!('message' in data) || (data.message is string && data.message.size() < 5000)) &&
             (!('notes' in data) || (data.notes is string && data.notes.size() < 5000)) &&
             (!('deliveryTime' in data) || (data.deliveryTime is string && data.deliveryTime.size() < 128)) &&
             (!('supplierName' in data) || (data.supplierName is string && data.supplierName.size() < 256)) &&
             (!('supplierCompanyName' in data) || (data.supplierCompanyName is string && data.supplierCompanyName.size() < 256)) &&
             (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() < 64)) &&
             (!('minPrice' in data) || (data.minPrice == null || data.minPrice is number)) &&
             (!('autoNegotiate' in data) || data.autoNegotiate is bool) &&
             (!('deletedAt' in data) || (data.deletedAt is string && data.deletedAt.size() < 64));
    }

    match /offers/{offerId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (resource != null && (resource.data.supplierId == request.auth.uid || resource.data.customerId == request.auth.uid))
      );
      allow create: if (isSupplier() || isAdmin()) && incoming().supplierId == request.auth.uid && isValidOffer(incoming());
      allow update: if isAuthenticated() && (
        (isAdmin() && isValidOffer(incoming())) ||
        (resource.data.supplierId == request.auth.uid && 
         isValidOffer(incoming()) && 
         existing().status == 'pending' && // Locking if already accepted/rejected
         incoming().supplierId == existing().supplierId // Immutability
        ) ||
        (resource.data.customerId == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
         incoming().status in ['accepted', 'rejected']
        )
      );
      allow delete: if false; // Soft delete only
    }

    function isValidChat(data) {
      return data.keys().hasAll(['customerId', 'supplierId', 'updatedAt']) &&
             data.customerId is string && data.customerId.size() < 128 &&
             data.supplierId is string && data.supplierId.size() < 128 &&
             data.updatedAt is string && data.updatedAt.size() < 64 &&
             (!('requestId' in data) || (data.requestId is string && data.requestId.size() < 128)) &&
             (!('lastMessage' in data) || (data.lastMessage is string && data.lastMessage.size() < 5000)) &&
             (!('isCategoryChat' in data) || data.isCategoryChat is bool) &&
             (!('categoryId' in data) || (data.categoryId is string && data.categoryId.size() < 128)) &&
             (!('status' in data) || data.status in ['active', 'closed', 'deleted']) &&
             (!('rating' in data) || (data.rating is number && data.rating >= 0 && data.rating <= 5)) &&
             (!('review' in data) || (data.review is string && data.review.size() < 2000)) &&
             (!('deletedAt' in data) || (data.deletedAt is string && data.deletedAt.size() < 64));
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (resource != null && (
          resource.data.customerId == request.auth.uid || 
          resource.data.supplierId == request.auth.uid || 
          resource.data.get('isCategoryChat', false) == true ||
          chatId.matches(".*" + request.auth.uid + ".*")
        ))
      );
      allow create: if isAuthenticated() && (
        request.resource.data.customerId == request.auth.uid || 
        request.resource.data.supplierId == request.auth.uid ||
        chatId.matches(".*" + request.auth.uid + ".*") ||
        isAdmin()
      ) && isValidChat(request.resource.data);
      allow update: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid || 
        resource.data.supplierId == request.auth.uid || 
        (resource.data.keys().contains('isCategoryChat') && resource.data.isCategoryChat == true) ||
        chatId.matches(".*" + request.auth.uid + ".*") ||
        isAdmin()
      ) && isValidChat(request.resource.data);
      allow delete: if false; // Soft delete only

      match /messages/{messageId} {
        allow read: if isAuthenticated() && (
          (get(/databases/$(database)/documents/chats/$(chatId)).data.customerId == request.auth.uid || 
           get(/databases/$(database)/documents/chats/$(chatId)).data.supplierId == request.auth.uid || 
           (get(/databases/$(database)/documents/chats/$(chatId)).data.keys().contains('isCategoryChat') && get(/databases/$(database)/documents/chats/$(chatId)).data.isCategoryChat == true) ||
           chatId.matches(".*" + request.auth.uid + ".*")) ||
          isAdmin()
        );
        allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
        allow update: if isAuthenticated() && (
          (get(/databases/$(database)/documents/chats/$(chatId)).data.customerId == request.auth.uid || 
           get(/databases/$(database)/documents/chats/$(chatId)).data.supplierId == request.auth.uid) || 
          isAdmin()
        );
        allow delete: if false; // Soft delete only
      }
    }

    function isValidMatchmakingCache(data) {
      return data.keys().hasAll(['key', 'supplierIds', 'createdAt']) &&
             data.key is string && data.key.size() < 1000 &&
             data.supplierIds is list && data.supplierIds.size() < 100 &&
             data.createdAt is string && data.createdAt.size() < 64;
    }

    match /matchmaking_cache/{cacheId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMatchmakingCache(request.resource.data);
      allow update: if isAuthenticated() && isValidMatchmakingCache(request.resource.data);
      allow delete: if isAdmin();
    }

    function isValidCategorizationCache(data) {
      return data.keys().hasAll(['key', 'categoryId', 'createdAt']) &&
             data.key is string && data.key.size() < 1000 &&
             data.categoryId is string && data.categoryId.size() < 64 &&
             data.createdAt is string && data.createdAt.size() < 64;
    }

    match /categorization_cache/{cacheId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidCategorizationCache(request.resource.data);
      allow update: if isAuthenticated() && isValidCategorizationCache(request.resource.data);
      allow delete: if isAdmin();
    }

    function isValidEnhancementCache(data) {
      return data.keys().hasAll(['key', 'enhancedDescription', 'createdAt']) &&
             data.key is string && data.key.size() < 1000 &&
             data.enhancedDescription is string && data.enhancedDescription.size() < 10000 &&
             data.createdAt is string && data.createdAt.size() < 64;
    }

    match /enhancement_cache/{cacheId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidEnhancementCache(request.resource.data);
      allow update: if isAuthenticated() && isValidEnhancementCache(request.resource.data);
      allow delete: if isAdmin();
    }

    function isValidPriceIntelligenceCache(data) {
      return data.keys().hasAll(['key', 'result', 'createdAt']) &&
             data.key is string && data.key.size() < 1000 &&
             data.result is map &&
             data.result.recommendedPrice is number &&
             data.result.minPrice is number &&
             data.result.maxPrice is number &&
             data.result.analysis is string && data.result.analysis.size() < 5000 &&
             data.createdAt is string && data.createdAt.size() < 64;
    }

    match /price_intelligence_cache/{cacheId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPriceIntelligenceCache(request.resource.data);
      allow update: if isAuthenticated() && isValidPriceIntelligenceCache(request.resource.data);
      allow delete: if isAdmin();
    }

    function isValidImageAnalysisCache(data) {
      return data.keys().hasAll(['hash', 'language', 'result', 'createdAt']) &&
             data.hash is string && data.hash.size() < 1000 &&
             data.language in ['ar', 'en'] &&
             data.result is map &&
             data.createdAt is string && data.createdAt.size() < 64;
    }

    match /image_analysis_cache/{cacheId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidImageAnalysisCache(request.resource.data);
      allow update: if isAuthenticated() && isValidImageAnalysisCache(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/site {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/gemini_config {
      allow read, write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/features {
      allow read: if true;
      allow write: if isAdmin();
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'titleAr', 'titleEn', 'bodyAr', 'bodyEn', 'read', 'createdAt']) &&
             data.userId is string &&
             data.titleAr is string && data.titleAr.size() < 256 &&
             data.titleEn is string && data.titleEn.size() < 256 &&
             data.bodyAr is string && data.bodyAr.size() < 1024 &&
             data.bodyEn is string && data.bodyEn.size() < 1024 &&
             data.read is bool &&
             (!('link' in data) || (data.link is string && data.link.size() < 512)) &&
             data.createdAt is string && data.createdAt.size() < 64;
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow create: if isAuthenticated() && isValidNotification(request.resource.data);
      allow update: if isAuthenticated() && (isAdmin() || (resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    function isValidModerationAlert(data) {
      return data.keys().hasAll(['chatId', 'senderId', 'text', 'reason', 'createdAt', 'resolved']) &&
             data.chatId is string &&
             data.senderId is string &&
             data.text is string && data.text.size() < 5000 &&
             data.reason is string && data.reason.size() < 1024 &&
             data.createdAt is string && data.createdAt.size() < 64 &&
             data.resolved is bool;
    }

    match /moderation_alerts/{alertId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidModerationAlert(request.resource.data);
      allow update: if isAdmin() && isValidModerationAlert(request.resource.data);
      allow delete: if isAdmin();
    }

    function isValidSearch(data) {
      return data.keys().hasAll(['query', 'userId', 'createdAt']) &&
             data.query is string && data.query.size() < 512 &&
             data.userId is string &&
             data.createdAt is string && data.createdAt.size() < 64;
    }

    match /searches/{searchId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidSearch(request.resource.data);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    function isValidTranslationCache(data) {
      return data.keys().hasAll(['text', 'targetLang', 'translation', 'createdAt']) &&
             data.text is string && data.text.size() < 10000 &&
             data.targetLang in ['English', 'Arabic'] &&
             data.translation is string && data.translation.size() < 10000 &&
             data.createdAt is string && data.createdAt.size() < 64;
    }

    match /translation_cache/{cacheId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTranslationCache(request.resource.data);
      allow update, delete: if isAdmin();
    }

    function isValidMarketTrend(data) {
      return data.keys().hasAll(['titleAr', 'titleEn', 'analysis', 'language', 'createdAt']) &&
             data.titleAr is string && data.titleAr.size() < 256 &&
             data.titleEn is string && data.titleEn.size() < 256 &&
             data.analysis is string && data.analysis.size() < 10000 &&
             (!('suggestions' in data) || (data.suggestions is list && data.suggestions.size() < 50)) &&
             data.language in ['ar', 'en'] &&
             data.createdAt is string && data.createdAt.size() < 64;
    }

    match /market_trends/{trendId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidMarketTrend(request.resource.data);
      allow delete: if isAdmin();
    }

    function isValidPriceInsight(data) {
      return data.keys().hasAll(['productName', 'recommendedPrice', 'minPrice', 'maxPrice', 'analysis', 'createdAt']) &&
             data.productName is string && data.productName.size() < 256 &&
             data.recommendedPrice is number &&
             data.minPrice is number &&
             data.maxPrice is number &&
             data.analysis is string && data.analysis.size() < 5000 &&
             data.createdAt is number;
    }

    match /price_insights/{insightId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidPriceInsight(request.resource.data);
      allow update: if isAdmin() && isValidPriceInsight(request.resource.data);
      allow delete: if isAdmin();
    }

    function isValidMarketplaceItem(data) {
      let allowedFields = ['sellerId', 'sellerName', 'sellerRole', 'title', 'titleAr', 'titleEn', 'description', 'descriptionAr', 'descriptionEn', 'price', 'currency', 'categories', 'images', 'status', 'location', 'createdAt', 'updatedAt', 'isVerifiedSupplier', 'phone', 'sellerPhone', 'isHighQuality', 'features', 'classification', 'views', 'deletedAt'];
      return data.keys().hasAll(['sellerId', 'title', 'price', 'status', 'createdAt']) &&
             data.sellerId is string && data.sellerId.size() > 0 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 256 &&
             data.price is number && data.price >= 0 &&
             data.status in ['active', 'sold', 'hidden', 'draft', 'deleted'] &&
             (!('titleAr' in data) || (data.titleAr is string && data.titleAr.size() < 256)) &&
             (!('titleEn' in data) || (data.titleEn is string && data.titleEn.size() < 256)) &&
             (!('sellerName' in data) || (data.sellerName is string && data.sellerName.size() < 256)) &&
             (!('sellerRole' in data) || (data.sellerRole is string && data.sellerRole.size() < 128)) &&
             (!('description' in data) || (data.description is string && data.description.size() < 5000)) &&
             (!('descriptionAr' in data) || (data.descriptionAr is string && data.descriptionAr.size() < 5000)) &&
             (!('descriptionEn' in data) || (data.descriptionEn is string && data.descriptionEn.size() < 5000)) &&
             (!('currency' in data) || (data.currency is string && data.currency.size() < 10)) &&
             (!('categories' in data) || (data.categories is list && data.categories.size() < 50)) &&
             (!('images' in data) || (data.images is list && data.images.size() <= 10)) &&
             (!('location' in data) || (data.location is string && data.location.size() < 512)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() < 30)) &&
             (!('sellerPhone' in data) || (data.sellerPhone is string && data.sellerPhone.size() < 30)) &&
             (!('updatedAt' in data) || (data.updatedAt is string && data.updatedAt.size() < 64)) &&
             (!('isVerifiedSupplier' in data) || data.isVerifiedSupplier is bool) &&
             (!('isHighQuality' in data) || data.isHighQuality is bool) &&
             (!('features' in data) || (data.features is list && data.features.size() <= 20)) &&
             (!('classification' in data) || (data.classification is string && data.classification.size() < 128)) &&
             (!('views' in data) || (data.views is number && data.views >= 0)) &&
             (!('deletedAt' in data) || (data.deletedAt is string && data.deletedAt.size() < 64));
    }

    match /marketplace/{itemId} {
      allow read: if true;
      allow create: if isAuthenticated() && incoming().sellerId == request.auth.uid && isValidMarketplaceItem(incoming());
      allow update: if isAuthenticated() && (
        (isAdmin() && isValidMarketplaceItem(incoming())) ||
        (resource.data.sellerId == request.auth.uid && 
         isValidMarketplaceItem(incoming()) &&
         incoming().sellerId == existing().sellerId && // Immutability
         incoming().createdAt == existing().createdAt    // Immutability
        ) 
      );
      allow delete: if false; // Soft delete only
    }

    function isValidContactEvent(data) {
      return data.keys().hasAll(['userId', 'supplierId', 'itemId', 'createdAt']) &&
             data.userId is string && data.userId.size() < 128 &&
             data.supplierId is string && data.supplierId.size() < 128 &&
             data.itemId is string && data.itemId.size() < 128 &&
             data.createdAt is string && data.createdAt.size() < 64;
    }

    match /contactEvents/{eventId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        resource.data.supplierId == request.auth.uid || 
        isAdmin()
      );
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidContactEvent(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    function isValidUsageLog(data) {
      let allowedFields = ['uid', 'email', 'feature', 'tokens', 'estimatedCost', 'isCached', 'createdAt'];
      return data.keys().hasAll(['uid', 'feature', 'tokens', 'createdAt']) &&
             data.keys().hasOnly(allowedFields) &&
             data.uid is string &&
             data.feature is string &&
             data.tokens is number &&
             data.createdAt is string &&
             (!('email' in data) || data.email is string) &&
             (!('estimatedCost' in data) || data.estimatedCost is number) &&
             (!('isCached' in data) || data.isCached is bool);
    }

    match /usage_logs/{logId} {
      allow read: if isAdmin();
      allow create: if (
        (isAuthenticated() && request.resource.data.uid == request.auth.uid) ||
        (!isAuthenticated() && request.resource.data.uid == 'anonymous')
      ) && isValidUsageLog(request.resource.data);
      allow update, delete: if isAdmin();
    }

    function isValidWithdrawalRequest(data) {
      let allowedFields = [
        'userId', 'userName', 'userEmail', 'points', 'amount', 'status', 'createdAt', 
        'processedAt', 'adminNotes', 'fraudScore', 'fraudAnalysis', 'fraudStatus', 'fraudRecommendations'
      ];
      return data.keys().hasAll(['userId', 'points', 'amount', 'status', 'createdAt']) &&
             data.keys().hasOnly(allowedFields) &&
             data.userId is string &&
             data.points is number && data.points >= 0 &&
             data.amount is number && data.amount >= 0 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.createdAt is string &&
             (!('userName' in data) || data.userName is string) &&
             (!('userEmail' in data) || data.userEmail is string) &&
             (!('processedAt' in data) || data.processedAt is string) &&
             (!('adminNotes' in data) || data.adminNotes is string) &&
             (!('fraudScore' in data) || data.fraudScore is number) &&
             (!('fraudAnalysis' in data) || data.fraudAnalysis is string) &&
             (!('fraudStatus' in data) || data.fraudStatus in ['safe', 'suspicious', 'high_risk']) &&
             (!('fraudRecommendations' in data) || data.fraudRecommendations is list);
    }

    match /withdrawal_requests/{requestId} {
      allow read: if isAuthenticated() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidWithdrawalRequest(request.resource.data);
      allow update: if isAdmin() && isValidWithdrawalRequest(request.resource.data);
      allow delete: if isAdmin();
    }

    function isValidCampaign(data) {
      let allowedFields = ['name', 'status', 'platform', 'budget', 'spent', 'conversions', 'clicks', 'startDate', 'endDate', 'createdAt'];
      return data.keys().hasAll(['name', 'status', 'platform', 'budget', 'createdAt']) &&
             data.keys().hasOnly(allowedFields) &&
             data.name is string && data.name.size() < 256 &&
             data.status in ['draft', 'active', 'paused', 'completed'] &&
             data.platform in ['meta', 'google'] &&
             data.budget is number && data.budget >= 0 &&
             (!('spent' in data) || (data.spent is number && data.spent >= 0)) &&
             (!('conversions' in data) || (data.conversions is number && data.conversions >= 0)) &&
             (!('clicks' in data) || (data.clicks is number && data.clicks >= 0)) &&
             (!('startDate' in data) || (data.startDate is string && data.startDate.size() < 64)) &&
             (!('endDate' in data) || (data.endDate is string && data.endDate.size() < 64)) &&
             data.createdAt is string && data.createdAt.size() < 64;
    }

    match /campaigns/{campaignId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidCampaign(request.resource.data);
      allow update: if isAdmin() && isValidCampaign(request.resource.data);
      allow delete: if isAdmin();

      function isValidCampaignAd(data) {
        let allowedFields = ['campaignId', 'title', 'text', 'imageUrl', 'status', 'createdAt'];
        return data.keys().hasAll(['campaignId', 'title', 'text', 'status', 'createdAt']) &&
               data.keys().hasOnly(allowedFields) &&
               data.campaignId is string && data.campaignId.size() < 128 &&
               data.title is string && data.title.size() < 256 &&
               data.text is string && data.text.size() < 5000 &&
               (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 1024)) &&
               data.status in ['draft', 'active', 'paused'] &&
               data.createdAt is string && data.createdAt.size() < 64;
      }

      match /ads/{adId} {
        allow read: if isAdmin();
        allow create: if isAdmin() && isValidCampaignAd(request.resource.data);
        allow update: if isAdmin() && isValidCampaignAd(request.resource.data);
        allow delete: if isAdmin();
      }
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Ad Analytics collection rules
    function isValidAdAnalytics(data) {
      let allowedFields = ['adId', 'sellerId', 'views', 'clicks', 'lastUpdated'];
      return data.keys().hasAll(['adId', 'sellerId', 'views', 'clicks', 'lastUpdated']) &&
             data.keys().hasOnly(allowedFields) &&
             data.adId is string && data.adId.size() > 0 &&
             data.sellerId is string && data.sellerId.size() > 0 &&
             data.views is number && data.views >= 0 &&
             data.clicks is number && data.clicks >= 0 &&
             data.lastUpdated is string && data.lastUpdated.size() < 64;
    }

    match /ad_analytics/{adId} {
      allow read: if isAuthenticated() && (isAdmin() || (resource != null && resource.data.sellerId == request.auth.uid));
      allow create: if isAuthenticated() && request.resource.data.sellerId == request.auth.uid && isValidAdAnalytics(request.resource.data);
      allow update: if isAuthenticated() && (
        (resource.data.sellerId == request.auth.uid &&
         isValidAdAnalytics(request.resource.data) &&
         request.resource.data.sellerId == resource.data.sellerId &&
         request.resource.data.adId == resource.data.adId
        ) ||
        (
          // Allow anyone to increment views/clicks
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'clicks', 'lastUpdated']) &&
          (request.resource.data.views == resource.data.views + 1 || request.resource.data.views == resource.data.views) &&
          (request.resource.data.clicks == resource.data.clicks + 1 || request.resource.data.clicks == resource.data.clicks)
        ) ||
        isAdmin()
      );
      allow delete: if false; // Soft delete only
    }

    // Ads collection rules
    function isValidAd(data) {
      let allowedFields = ['title', 'sellerId', 'status', 'views', 'clicks', 'spend', 'createdAt', 'deletedAt'];
      return data.keys().hasAll(['title', 'sellerId', 'status', 'views', 'clicks', 'spend', 'createdAt']) &&
             data.keys().hasOnly(allowedFields) &&
             data.title is string && data.title.size() < 256 &&
             data.sellerId is string && data.sellerId.size() > 0 &&
             data.status in ['active', 'paused', 'ended', 'deleted'] &&
             data.views is number && data.views >= 0 &&
             data.clicks is number && data.clicks >= 0 &&
             data.spend is number && data.spend >= 0 &&
             data.createdAt is string && data.createdAt.size() < 64 &&
             (!('deletedAt' in data) || (data.deletedAt is string && data.deletedAt.size() < 64));
    }

    match /ads/{adId} {
      allow read: if isAuthenticated() && (isAdmin() || (resource != null && resource.data.sellerId == request.auth.uid));
      allow create: if isAuthenticated() && request.resource.data.sellerId == request.auth.uid && isValidAd(request.resource.data);
      allow update: if isAuthenticated() && (
        (resource.data.sellerId == request.auth.uid &&
         isValidAd(request.resource.data) &&
         request.resource.data.sellerId == resource.data.sellerId &&
         request.resource.data.createdAt == resource.data.createdAt
        ) ||
        isAdmin()
      );
      allow delete: if false; // Soft delete only
    }

    // Reports collection rules
    function isValidReport(data) {
      let allowedFields = ['reporterId', 'reporterName', 'targetId', 'targetType', 'targetOwnerId', 'reason', 'details', 'status', 'createdAt'];
      return data.keys().hasAll(['reporterId', 'targetId', 'targetType', 'reason', 'status', 'createdAt']) &&
             data.keys().hasOnly(allowedFields) &&
             data.reporterId == request.auth.uid &&
             data.targetId is string && data.targetId.size() > 0 &&
             data.targetType in ['marketplace_item', 'user'] &&
             data.reason is string && data.reason.size() > 0 && data.reason.size() < 500 &&
             (!('details' in data) || (data.details is string && data.details.size() < 2000)) &&
             data.status in ['pending', 'reviewed', 'resolved', 'dismissed'] &&
             data.createdAt is string && data.createdAt.size() < 64;
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidReport(request.resource.data);
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Performance and Demand Insights rules
    function isValidSupplierPerformance(data) {
      return data.keys().hasAll(['supplierId', 'avgResponseTime', 'matchRate', 'calculatedAt']) &&
             data.supplierId is string &&
             data.avgResponseTime is number &&
             data.matchRate is number &&
             data.calculatedAt is string;
    }

    match /supplier_performance/{supplierId} {
      allow read: if isAuthenticated() && (request.auth.uid == supplierId || isAdmin());
      allow write: if isAdmin();
    }

    function isValidDemandInsight(data) {
      return data.keys().hasAll(['categoryId', 'missedOpportunityCount', 'lastUpdated']) &&
             data.categoryId is string &&
             data.missedOpportunityCount is number &&
             data.lastUpdated is string;
    }

    match /demand_insights/{insightId} {
      allow read: if isAuthenticated() && (isSupplier() || isAdmin());
      allow write: if isAdmin();
    }

    function isValidPulse(data) {
      let allowedFields = ['userId', 'targetId', 'type', 'metadata', 'timestamp'];
      return data.keys().hasAll(['userId', 'targetId', 'type', 'timestamp']) &&
             data.keys().hasOnly(allowedFields) &&
             data.userId == request.auth.uid &&
             data.targetId is string &&
             data.type in ['view', 'click', 'search'] &&
             data.timestamp is string;
    }

    match /neural_pulse/{pulseId} {
      allow create: if isAuthenticated() && isValidPulse(request.resource.data);
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // Connection Test Rule
    match /test/connection {
      allow read: if true;
    }
  }
}
