rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Publicly readable
    match /{allPaths=**} {
      allow read: if true;
    }

    // Logos directory - authenticated users can upload
    match /logos/{allPaths=**} {
      allow write: if request.auth != null;
    }

    // Chat attachments - authenticated users can upload
    match /chats/{chatId}/{allPaths=**} {
      allow write: if request.auth != null;
    }
    
    // Default allow for authenticated users for other paths
    match /{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}
