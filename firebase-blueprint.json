{
  "entities": {
    "User": {
      "title": "User",
      "description": "System users (Customers, Suppliers, Admins) - Private Data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "supplier", "customer"] },
        "companyName": { "type": "string" },
        "phone": { "type": "string" },
        "logoUrl": { "type": "string" },
        "slug": { "type": "string", "description": "SEO friendly URL slug" },
        "metaTitleAr": { "type": "string" },
        "metaTitleEn": { "type": "string" },
        "metaDescriptionAr": { "type": "string" },
        "metaDescriptionEn": { "type": "string" },
        "seoKeywords": { "type": "array", "items": { "type": "string" } },
        "verificationDocUrl": { "type": "string", "description": "URL of the uploaded verification document" },
        "isVerified": { "type": "boolean", "description": "Whether the supplier is verified by AI/Admin" },
        "verificationDetails": { "type": "string", "description": "Details extracted from the document" },
        "categories": { "type": "array", "items": { "type": "string" }, "description": "Categories the supplier works in" },
        "keywords": { "type": "array", "items": { "type": "string" }, "description": "Manual keywords added by the supplier" },
        "language": { "type": "string", "enum": ["ar", "en"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" },
        "following": { "type": "array", "items": { "type": "string" }, "description": "List of supplier UIDs the user is following" },
        "referralPoints": { "type": "integer" },
        "neuralCredits": { "type": "integer", "description": "Virtual currency for AI features" },
        "subscriptionPlan": { "type": "string", "enum": ["basic", "pro", "enterprise"] },
        "subscriptionExpiry": { "type": "string", "format": "date-time" },
        "referralCode": { "type": "string" },
        "notificationPreferences": {
          "type": "object",
          "description": "User notification preferences",
          "properties": {
            "newMessages": { "type": "boolean" },
            "newOffers": { "type": "boolean" },
            "requestUpdates": { "type": "boolean" },
            "verificationStatus": { "type": "boolean" }
          }
        }
      },
      "required": ["uid", "email", "role"]
    },
    "UserPublic": {
      "title": "UserPublic",
      "description": "Public profile data for suppliers/users",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["supplier", "customer"] },
        "companyName": { "type": "string" },
        "logoUrl": { "type": "string" },
        "slug": { "type": "string", "description": "SEO friendly URL slug" },
        "metaTitleAr": { "type": "string" },
        "metaTitleEn": { "type": "string" },
        "metaDescriptionAr": { "type": "string" },
        "metaDescriptionEn": { "type": "string" },
        "seoKeywords": { "type": "array", "items": { "type": "string" } },
        "isVerified": { "type": "boolean" },
        "categories": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number" },
        "reviewCount": { "type": "integer" },
        "isOnline": { "type": "boolean" },
        "averageResponseTime": { "type": "number" }
      },
      "required": ["uid", "name", "role"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories including Hubs, Sectors, and Niches",
      "type": "object",
      "properties": {
        "nameAr": { "type": "string" },
        "nameEn": { "type": "string" },
        "parentId": { "type": "string", "description": "ID of the parent category for hierarchy" },
        "order": { "type": "integer" },
        "keywords": { "type": "array", "items": { "type": "string" }, "description": "Active keywords for search optimization" },
        "suggestedKeywords": { "type": "array", "items": { "type": "string" }, "description": "Keywords suggested by AI from user requests" },
        "iconName": { "type": "string", "description": "Lucide icon name for display" },
        "imageUrl": { "type": "string", "description": "Image for the category hub" },
        "tier": { "type": "string", "enum": ["hub", "sector", "niche"], "description": "Hierarchy level" },
        "status": { "type": "string", "enum": ["active", "hidden", "deleted"] },
        "slug": { "type": "string", "description": "SEO friendly URL slug" },
        "descriptionAr": { "type": "string", "description": "Long Arabic description for SEO" },
        "descriptionEn": { "type": "string", "description": "Long English description for SEO" },
        "seoKeywords": { "type": "array", "items": { "type": "string" }, "description": "Specific keywords for SEO targeting" },
        "metaTitleAr": { "type": "string" },
        "metaTitleEn": { "type": "string" }
      },
      "required": ["nameAr", "nameEn", "tier"]
    },
    "Request": {
      "title": "Request",
      "description": "Customer product requests",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "productName": { "type": "string" },
        "description": { "type": "string" },
        "categoryId": { "type": "string" },
        "categoryNameAr": { "type": "string" },
        "categoryNameEn": { "type": "string" },
        "quantity": { "type": "string" },
        "urgency": { "type": "string", "enum": ["normal", "high", "critical"] },
        "budget": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "offerCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "productName", "categoryId", "status"]
    },
    "Offer": {
      "title": "Offer",
      "description": "Supplier price offers",
      "type": "object",
      "properties": {
        "requestId": { "type": "string" },
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "supplierCompanyName": { "type": "string" },
        "price": { "type": "number" },
        "minPrice": { "type": "number", "description": "Minimum price for auto-negotiation (hidden from customer)" },
        "autoNegotiate": { "type": "boolean", "description": "Whether AI bot should handle negotiations" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["requestId", "supplierId", "price", "status"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Private chat between customer and supplier",
      "type": "object",
      "properties": {
        "requestId": { "type": "string" },
        "customerId": { "type": "string" },
        "supplierId": { "type": "string" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["requestId", "customerId", "supplierId"]
    },
    "Message": {
      "title": "Message",
      "description": "Individual chat messages",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "audioUrl": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "audio"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "type"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global site settings",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string" },
        "siteName": { "type": "string" },
        "heroTitleAr": { "type": "string" },
        "heroTitleEn": { "type": "string" },
        "heroDescriptionAr": { "type": "string" },
        "heroDescriptionEn": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "titleAr": { "type": "string" },
        "titleEn": { "type": "string" },
        "bodyAr": { "type": "string" },
        "bodyEn": { "type": "string" },
        "link": { "type": "string" },
        "actionType": { "type": "string", "enum": ["submit_offer", "accept_chat", "general", "new_request"] },
        "targetId": { "type": "string" },
        "matchScore": { "type": "number" },
        "matchReasonAr": { "type": "string" },
        "matchReasonEn": { "type": "string" },
        "isUrgent": { "type": "boolean" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "titleAr", "titleEn", "bodyAr", "bodyEn", "read", "createdAt"]
    },
    "ModerationAlert": {
      "title": "ModerationAlert",
      "description": "Alerts for blocked content",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "reason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "resolved": { "type": "boolean" }
      },
      "required": ["chatId", "senderId", "text", "reason", "createdAt", "resolved"]
    },
    "Search": {
      "title": "Search",
      "description": "User search history",
      "type": "object",
      "properties": {
        "query": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["query", "userId", "createdAt"]
    },
    "TranslationCache": {
      "title": "TranslationCache",
      "description": "Cache for AI translations to reduce API calls and costs",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The original text to translate" },
        "targetLang": { "type": "string", "enum": ["English", "Arabic"] },
        "translation": { "type": "string", "description": "The translated text" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "targetLang", "translation", "createdAt"]
    },
    "MarketTrend": {
      "title": "MarketTrend",
      "description": "AI analyzed market trends and demand forecasting",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "analysis": { "type": "string" },
        "suggestions": { "type": "array", "items": { "type": "string" } },
        "language": { "type": "string", "enum": ["ar", "en"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "analysis", "language", "createdAt"]
    },
    "MarketplaceItem": {
      "title": "MarketplaceItem",
      "description": "Items listed for sale in the marketplace",
      "type": "object",
      "properties": {
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "sellerRole": { "type": "string", "enum": ["admin", "supplier", "customer"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "sold", "hidden"] },
        "location": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "isVerifiedSupplier": { "type": "boolean" }
      },
      "required": ["sellerId", "title", "price", "status", "createdAt"]
    },
    "AppFeatures": {
      "title": "AppFeatures",
      "description": "Toggles for enabling/disabling app features",
      "type": "object",
      "properties": {
        "marketplace": { "type": "boolean" },
        "aiChat": { "type": "boolean" },
        "supplierVerification": { "type": "boolean" },
        "marketTrends": { "type": "boolean" },
        "priceIntelligence": { "type": "boolean" }
      }
    },
    "UsageLog": {
      "title": "UsageLog",
      "description": "Logs for AI resource usage and cost tracking",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "feature": { "type": "string" },
        "tokens": { "type": "integer" },
        "estimatedCost": { "type": "number" },
        "isCached": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "feature", "tokens", "createdAt"]
    },
    "WithdrawalRequest": {
      "title": "WithdrawalRequest",
      "description": "User requests to redeem points for cash",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "points": { "type": "integer" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "processedAt": { "type": "string", "format": "date-time" },
        "adminNotes": { "type": "string" },
        "fraudScore": { "type": "number" },
        "fraudAnalysis": { "type": "string" },
        "fraudStatus": { "type": "string", "enum": ["safe", "suspicious", "high_risk"] },
        "fraudRecommendations": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["userId", "points", "amount", "status", "createdAt"]
    },
    "Campaign": {
      "title": "Campaign",
      "description": "Marketing campaigns for platform growth",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "active", "paused", "completed"] },
        "platform": { "type": "string", "enum": ["meta", "google"] },
        "budget": { "type": "number" },
        "spent": { "type": "number" },
        "conversions": { "type": "integer" },
        "clicks": { "type": "integer" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status", "platform", "budget", "createdAt"]
    },
    "CampaignAd": {
      "title": "CampaignAd",
      "description": "Individual ads within a campaign",
      "type": "object",
      "properties": {
        "campaignId": { "type": "string" },
        "title": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "active", "paused"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["campaignId", "title", "text", "status", "createdAt"]
    },
    "Report": {
      "title": "Report",
      "description": "User reports on inappropriate content",
      "type": "object",
      "properties": {
        "reporterId": { "type": "string" },
        "reporterName": { "type": "string" },
        "targetId": { "type": "string", "description": "ID of the reported item (marketplace item, user, etc.)" },
        "targetType": { "type": "string", "enum": ["marketplace_item", "user"] },
        "targetOwnerId": { "type": "string", "description": "UID of the user who owns the reported content" },
        "reason": { "type": "string" },
        "details": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "resolved", "dismissed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["reporterId", "targetId", "targetType", "reason", "status", "createdAt"]
    },
    "Activity": {
      "title": "Activity",
      "description": "Log of user actions for transparency and engagement",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["message_sent", "request_created", "offer_received", "profile_updated", "login", "view_product"] },
        "descriptionAr": { "type": "string" },
        "descriptionEn": { "type": "string" },
        "metadata": { "type": "object", "description": "Dynamic data like requestId or chatId" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "descriptionAr", "descriptionEn", "createdAt"]
    },
    "PasskeyCredential": {
      "title": "PasskeyCredential",
      "description": "Biometric/Hardware keys for passwordless authentication",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "credentialId": { "type": "string" },
        "publicKey": { "type": "string" },
        "name": { "type": "string" },
        "deviceType": { "type": "string" },
        "lastUsedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "credentialId", "publicKey", "name", "createdAt"]
    },
    "PasskeyIdentity": {
      "title": "PasskeyIdentity",
      "description": "Mapping for finding user by credential ID without being logged in",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "credentialId": { "type": "string" },
        "publicKey": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "credentialId", "publicKey", "createdAt"]
    },
    "SupplierPerformance": {
      "title": "SupplierPerformance",
      "description": "Calculated metrics for supplier responsiveness and matching accuracy",
      "type": "object",
      "properties": {
        "supplierId": { "type": "string" },
        "avgResponseTime": { "type": "number" },
        "matchRate": { "type": "number" },
        "unmetDemandHits": { "type": "number", "description": "How many unfulfilled requests this supplier could have served" },
        "suggestions": { "type": "array", "items": { "type": "string" } },
        "calculatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["supplierId", "avgResponseTime", "matchRate", "calculatedAt"]
    },
    "DemandInsight": {
      "title": "DemandInsight",
      "description": "Aggregated data on what users are looking for but can't find",
      "type": "object",
      "properties": {
        "categoryId": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "missedOpportunityCount": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["categoryId", "missedOpportunityCount", "lastUpdated"]
    },
    "NeuralPulse": {
      "title": "NeuralPulse",
      "description": "Real-time user behavior tracking (AI Pulse)",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "targetId": { "type": "string" },
        "type": { "type": "string", "enum": ["view", "click", "search"] },
        "metadata": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "targetId", "type", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles - Private Data" },
    "/users/{userId}/passkeys/{keyId}": { "schema": "PasskeyCredential", "description": "User biometrics keys" },
    "/passkey_identities/{credentialId}": { "schema": "PasskeyIdentity", "description": "Global Passkey to User mapping" },
    "/users_public/{userId}": { "schema": "UserPublic", "description": "Public user profiles" },
    "/categories/{categoryId}": { "schema": "Category", "description": "Product categories" },
    "/requests/{requestId}": { "schema": "Request", "description": "Customer requests" },
    "/offers/{offerId}": { "schema": "Offer", "description": "Supplier offers" },
    "/chats/{chatId}": { "schema": "Chat", "description": "Chat sessions" },
    "/chats/{chatId}/messages/{messageId}": { "schema": "Message", "description": "Chat messages" },
    "/settings/{settingId}": { "schema": "Settings", "description": "Global site settings" },
    "/settings/features": { "schema": "AppFeatures", "description": "Feature toggles" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications" },
    "/moderation_alerts/{alertId}": { "schema": "ModerationAlert", "description": "Moderation alerts" },
    "/searches/{searchId}": { "schema": "Search", "description": "User search history" },
    "/translation_cache/{cacheId}": { "schema": "TranslationCache", "description": "Cache for AI translations" },
    "/market_trends/{trendId}": { "schema": "MarketTrend", "description": "AI analyzed market trends" },
    "/marketplace/{itemId}": { "schema": "MarketplaceItem", "description": "Marketplace listings" },
    "/usage_logs/{logId}": { "schema": "UsageLog", "description": "AI usage and cost logs" },
    "/withdrawal_requests/{requestId}": { "schema": "WithdrawalRequest", "description": "User withdrawal requests" },
    "/campaigns/{campaignId}": { "schema": "Campaign", "description": "Marketing campaigns" },
    "/campaigns/{campaignId}/ads/{adId}": { "schema": "CampaignAd", "description": "Campaign ads" },
    "/reports/{reportId}": { "schema": "Report", "description": "User reports" },
    "/activities/{activityId}": { "schema": "Activity", "description": "User daily movement logs" },
    "/supplier_performance/{supplierId}": { "schema": "SupplierPerformance", "description": "Supplier performance metrics" },
    "/demand_insights/{insightId}": { "schema": "DemandInsight", "description": "Market demand analysis" },
    "/neural_pulse/{pulseId}": { "schema": "NeuralPulse", "description": "User behavior tracking logs" }
  }
}
